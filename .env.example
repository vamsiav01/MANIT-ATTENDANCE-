# MANIT Attendance App — Environment Variables
# Copy this file to .env and fill in your values

# ─── Gemini AI Assistant ───────────────────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/app/apikey
# Required for the AI Attendance Assistant chatbot feature
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase (Cloud Sync) ─────────────────────────────────────────────────────
# Already configured in src/config/firebase.js
# Add here only if you want to override via environment variables
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
